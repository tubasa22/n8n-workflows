      ],
      "id": "cc78d2b4-6449-4faf-a101-9b168dcf3981",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "iv232yP0DvqiYqDp",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const output = item.json.output;\n  \n  // 1. hook (도입부)\n  let fullText = `${output.hook}\\n\\n`;\n  \n  // 2. content (본문 배열 합치기)\n  if (Array.isArray(output.content)) {\n    fullText += output.content.join('\\n');\n  }\n  \n  // 3. cta (맺음말)\n  fullText += `\\n\\n${output.cta}`;\n\n  // 결과를 새로운 필드 'ttsText'에 담아 반환\n  item.json.ttsText = fullText;\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        0
      ],
      "id": "35976be3-6001-4b7e-8f59-e7987a8a6ab5",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// 1. 데이터 가져오기 (문자열일 경우를 대비해 파싱)\nlet rawData = $input.all()[0].json.output;\n\n// 만약 output이 문자열(String)로 들어왔다면 JSON 객체로 변환\nif (typeof rawData === 'string') {\n  try {\n    rawData = JSON.parse(rawData);\n  } catch (e) {\n    // 파싱 실패 시 에러 방지를 위해 빈 객체 처리\n    rawData = { content: [] };\n  }\n}\n\nconst results = [];\n\n// 2. Hook 추가\nif (rawData.hook) {\n  results.push({ json: { text: rawData.hook, type: 'hook' } });\n}\n\n// 3. Content 배열 분리 (가장 중요한 부분)\nif (rawData.content && Array.isArray(rawData.content)) {\n  rawData.content.forEach((line, index) => {\n    results.push({ json: { text: line, type: 'content', index: index } });\n  });\n}\n\n// 4. CTA 추가\nif (rawData.cta) {\n  results.push({ json: { text: rawData.cta, type: 'cta' } });\n}\n\nreturn results;"
      },
