    {
      "parameters": {
        "jsCode": "// 기존 내용을 모두 지우고 이 코드만 붙여넣으세요.\nconst inputData = $json.text;\n\n// 1. 데이터가 이미 객체인 경우 처리\nif (typeof inputData === 'object' && inputData !== null) {\n  return inputData;\n}\n\ntry {\n  // 2. 텍스트 양 끝 공백 제거 후 파싱\n  const cleanedText = inputData.trim();\n  const parsed = JSON.parse(cleanedText);\n\n  // 3. 필드 보정 (기본값 설정)\n  if (!parsed.date) parsed.date = new Date().toISOString().split('T')[0];\n  if (!parsed.time) parsed.time = \"00:00\";\n  if (!parsed.action) parsed.action = \"read\";\n\n  return parsed;\n\n} catch (e) {\n  // 4. 파싱 실패 시 정규표현식으로 JSON 형태만 추출 시도\n  const match = inputData.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    try {\n      return JSON.parse(match[0]);\n    } catch (innerError) {\n      return { action: \"chat\", activity: \"파싱 최종 실패\", raw: inputData };\n    }\n  }\n  \n  // 5. JSON 형식이 전혀 없는 경우 일반 채팅으로 반환\n  return { action: \"chat\", activity: inputData };\n}"
      },
