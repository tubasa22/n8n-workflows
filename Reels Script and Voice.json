    {
      "parameters": {
        "jsCode": "try {\n  const input = items[0].json.output;\n  // 정규식: { 로 시작해서 } 로 끝나는 가장 긴 부분을 찾음\n  const match = input.match(/\\{[\\s\\S]*\\}/);\n  \n  if (!match) throw new Error(\"JSON을 찾을 수 없습니다.\");\n  \n  return { json: JSON.parse(match[0]) };\n\n} catch (e) {\n  return { json: { error: \"파싱 실패\", raw: items[0].json.output } };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        0
      ],
      "id": "ab444c87-7d47-4cc4-8c71-1660d64574dd",
      "name": "Code in Java full script"
    },
    {
      "parameters": {
        "jsCode": "try {\n  const input = items[0].json;\n  let fullText = \"\";\n\n  // 1. 데이터가 이미 구조화되어 있는 경우 (예: full_script 필드가 있는 경우)\n  if (input.full_script) {\n    fullText = input.full_script;\n  } \n  // 2. 데이터가 raw라는 문자열로 들어온 경우 (파싱 필요)\n  else if (input.raw) {\n    let rawData = input.raw.replace(/[\\r\\n]+/g, \" \");\n    const match = rawData.match(/\\{[\\s\\S]*\\}/);\n    if (match) {\n      fullText = JSON.parse(match[0]).full_script;\n    } else {\n      fullText = rawData; // 매칭이 안 되면 원문을 그대로 사용\n    }\n  } else {\n    throw new Error(\"데이터를 찾을 수 없습니다. Input 필드를 확인하세요.\");\n  }\n\n  // 3. 문장 나누기 (공통 작업)\n  const sentences = fullText.match(/[^.?!]+[.?!](\\s|$)/g) || [fullText];\n  \n  return {\n    json: {\n      script_array: sentences.map(s => s.trim())\n    }\n  };\n} catch (e) {\n  return { \n    json: { \n      error: \"데이터 처리 실패\", \n      details: e.message \n    } \n  };\n}"
      },
